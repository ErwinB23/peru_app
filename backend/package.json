{
  "name": "backend-peru-departamentos",
  "version": "1.0.0",
  "description": "API REST para gestión de departamentos del Perú",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/unit --runInBand",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/integration --runInBand",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --coverage --json --outputFile=reports/jest/results.json",
    "test:api": "node scripts/runNewman.js",
    "qa:seed": "node scripts/createQaUsers.js",
    "pretest:coverage": "node scripts/ensureReportDirs.js",
    "pretest:api": "node scripts/ensureReportDirs.js",
    "cloudinary:check": "node scripts/checkCloudinary.js",
    "cloudinary:migrate:dry": "node scripts/migrateLocalImagesToCloudinary.js --dry-run",
    "cloudinary:migrate": "node scripts/migrateLocalImagesToCloudinary.js --apply"
  },
  "keywords": [
    "api",
    "peru",
    "departamentos"
  ],
  "author": "ERWIN BRAYAM INCA PAUCCARA",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^12.7.0",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "allowScripts": {
    "bcrypt@6.0.0": true,
    "unrs-resolver@1.12.2": true
  }
}
