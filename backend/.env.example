# =============================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# =============================================
# CONFIGURACIÓN DE SQL SERVER
# =============================================
DB_SERVER=localhost
DB_DATABASE=PeruDepartamentosDB
DB_USER=sa
DB_PASSWORD=tu_password_seguro

# Opcionales:
# Usa DB_INSTANCE cuando trabajes con una instancia nombrada, por ejemplo SQLEXPRESS.
# También puedes escribir DB_SERVER=localhost\\SQLEXPRESS y dejar DB_INSTANCE vacío.
DB_INSTANCE=

# Deja DB_PORT vacío si utilizas una instancia nombrada.
DB_PORT=1433

# =============================================
# SEGURIDAD JWT
# =============================================
JWT_SECRET=cambia_esta_clave_por_una_clave_larga_y_segura
JWT_EXPIRE=1d
