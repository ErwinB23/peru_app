# =============================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================
PORT=5000
NODE_ENV=development
REQUEST_BODY_LIMIT=1mb

# Uno o varios orígenes autorizados, separados por coma y sin barra final.
FRONTEND_URLS=http://localhost:5173

# =============================================
# CONFIGURACIÓN DE SQL SERVER
# =============================================
DB_SERVER=localhost
DB_DATABASE=PeruDepartamentosDB
DB_USER=sa
DB_PASSWORD=tu_password_seguro

# Usa DB_INSTANCE con instancias nombradas, por ejemplo SQLEXPRESS.
# También puedes escribir DB_SERVER=localhost\SQLEXPRESS y dejar DB_INSTANCE vacío.
DB_INSTANCE=

# Deja DB_PORT vacío cuando utilices una instancia nombrada.
DB_PORT=1433

# =============================================
# SEGURIDAD JWT
# =============================================
JWT_SECRET=cambia_esta_clave_por_una_clave_larga_y_segura
JWT_EXPIRE=1d

# =============================================
# ALMACENAMIENTO DE IMAGENES
# =============================================
# Usa "local" durante desarrollo o "cloudinary" para Render/produccion.
IMAGE_STORAGE=local

# Obligatorias cuando IMAGE_STORAGE=cloudinary.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Carpeta raiz dentro de Cloudinary.
CLOUDINARY_FOLDER=peru-app/development
